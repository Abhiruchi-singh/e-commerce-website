PORT=5000
NODE_ENV=development
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/ecommerce-mern-stack?retryWrites=true&w=majority
USE_MEMORY_DB=false
JWT_SECRET=your_super_secret_jwt_key_change_this
CLIENT_URL=http://localhost:5173

# Razorpay (https://dashboard.razorpay.com) — Test keys for local dev
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Local with in-memory DB (no Atlas):
# USE_MEMORY_DB=true
# MONGODB_URI=mongodb://127.0.0.1:27017/ecommerce-mern-stack

# Render deploy — set in Render Environment Variables (not in code):
# NODE_ENV=production
# CLIENT_URL=https://your-app.onrender.com
